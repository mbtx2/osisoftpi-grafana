# Copy this file to .env and fill in your PI Web API details.
# docker compose will read .env automatically.

# Full URL to your PI Web API, e.g. https://mypiserver/piwebapi
PI_URL=https://piwebapi.example.com/piwebapi

# PI Web API credentials (Basic Auth)
PI_USER=domain\username
PI_PASSWORD=yourpassword

# Optional: set to "debug" to see streaming WebSocket activity in Grafana logs
GF_LOG_LEVEL=info

# Optional: override the Grafana image / version used by docker compose
# GRAFANA_IMAGE=grafana-oss
# GRAFANA_VERSION=10.3.3
